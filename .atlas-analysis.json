  "keyFeatures": [
    "Serverless architecture using Cloudflare Workers and Durable Objects",
    "Full Git Smart HTTP protocol implementation",
    "Unlimited public and private repositories",
    "Issues and comments tracking",
    "Web-based repository management interface",
    "Better Auth integration for authentication",
    "Global edge deployment with low latency",
    "Virtualized file system on Durable Object SQLite storage"
  ],
  "publicApiSurface": [
    "POST /git-receive-pack - Push changes to repository",
    "POST /git-upload-pack - Fetch changes from repository",
    "GET /api/repos - List repositories",
    "GET /api/repos/:owner/:repo/commits - Get commit history",
    "GET /api/repos/:owner/:repo/tree - Get repository tree",
    "GET /api/repos/:owner/:repo/branches - List branches",
    "GET /api/issues - List issues",
    "POST /api/issues - Create issue",
    "POST /api/comments - Create comment",
    "POST /api/session - Authentication session management"
  ]
